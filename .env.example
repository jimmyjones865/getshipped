# DHL API credentials (developer.dhl.com)
DHL_CLIENT_ID=
DHL_CLIENT_SECRET=

# DHL Geschäftskundenportal credentials
DHL_GKP_USER=
DHL_GKP_PASSWORD=

# DHL account number (10-digit EKP)
DHL_EKP=
# Partner number (usually 01)
DHL_PARTNER_NO=01

# Set to true for sandbox/testing
DHL_TEST_MODE=false

# DHL account profile (usually leave as-is)
DHL_PROFILE=STANDARD_GRUPPENPROFIL

# Label format: A4, 910-300-700, 910-300-300, etc.
LABEL_FORMAT=A4

# Path to products.yaml (inside container)
PRODUCTS_FILE=/app/products.yaml

# Sender address
SENDER_NAME=
SENDER_STREET=
SENDER_HOUSE=
SENDER_ZIP=
SENDER_CITY=
SENDER_COUNTRY=DEU
SENDER_EMAIL=
SENDER_PHONE=

# PrintNode
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=

# Log retention in days (optional — unset keeps records forever)
# LOG_RETENTION_DAYS=90
